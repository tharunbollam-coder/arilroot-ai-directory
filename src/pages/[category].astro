---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Use getStaticPaths to generate all category pages at build time
export async function getStaticPaths() {
  const allModels = await getCollection('models');
  
  // Extract unique categories
  const categories = [...new Set(allModels.map(model => model.data.category))];
  
  // Map categories to parameters and pass matching models as props
  return categories.map(category => {
    const filteredModels = allModels.filter(model => model.data.category === category);
    return {
      params: { category },
      props: { models: filteredModels }
    };
  });
}

const { category } = Astro.params;
const { models } = Astro.props;

// Human-friendly mapping for category titles
const categoryDisplayNames: Record<string, string> = {
  'text-models': 'Text Models & Chatbots',
  'image-models': 'Image & Art Generators',
  'audio-models': 'Audio & Speech Synthesizers',
  'video-models': 'Video Generators',
};

const displayName = categoryDisplayNames[category] || category.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
---

<Layout 
  title={`${displayName} - ArilRoot AI Directory`}
  description={`Explore in-depth reviews, specifications, and comparison guides for the best ${displayName} AI models.`}
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto">
    
    <!-- Premium Breadcrumbs Navigation -->
    <nav class="flex mb-10 font-sans text-[10px] sm:text-xs font-bold uppercase tracking-[0.15em] text-stone-400" aria-label="Breadcrumb">
      <ol class="inline-flex flex-wrap items-center gap-y-2">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-stone-900 transition-colors">Home</a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3.5 h-3.5 mx-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            <span class="text-stone-800 font-bold">{displayName}</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Executive Header Section -->
    <header class="mb-12 border-b border-stone-200 pb-10">
      <span class="font-sans text-[10px] font-bold uppercase tracking-[0.15em] text-executive-blue mb-4 block">Category Directory</span>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-stone-900 leading-tight mb-6">
        {displayName}
      </h1>
      <p class="text-stone-600 text-lg sm:text-xl max-w-2xl font-normal leading-relaxed">
        A hand-picked selection of the most powerful models in the <span class="font-bold text-stone-900">{displayName}</span> ecosystem. Browse detailed capabilities, architectures, and full analysis sheets below.
      </p>
    </header>

    <!-- List of Models in Category -->
    <div class="space-y-8">
      {models.map((model) => {
        // Safe extraction of slug from ID (e.g. "text-models/chatgpt" -> "chatgpt")
        const modelSlug = model.id.split('/').pop();
        return (
          <article 
            id={`model-${modelSlug}`}
            class="executive-card p-6 sm:p-8 flex flex-col md:flex-row gap-6 md:gap-8 items-start"
          >
            <!-- Model Logo -->
            {model.data.logo && (
              <div class="w-20 h-20 rounded-2xl overflow-hidden bg-white border border-stone-200 p-3 flex-shrink-0 flex items-center justify-center shadow-sm">
                <img 
                  src={model.data.logo} 
                  alt={`${model.data.title} brand mark`} 
                  class="w-full h-full object-contain"
                  loading="lazy"
                />
              </div>
            )}
            
            <!-- Details Column -->
            <div class="flex-grow w-full">
              <!-- Meta Row -->
              <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                <div class="flex flex-wrap items-center gap-3">
                  <h2 class="font-serif text-2xl font-bold text-stone-900 hover:text-stone-600 transition-colors">
                    <a href={`/${category}/${modelSlug}`}>{model.data.title}</a>
                  </h2>
                  <span class="executive-badge">
                    by {model.data.creator}
                  </span>
                </div>
              </div>

              <!-- Summary Description -->
              <p class="text-stone-600 mb-6 leading-relaxed font-normal">
                {model.data.description}
              </p>

              <!-- Footer Row -->
              <div class="flex flex-wrap items-center justify-between gap-4 border-t border-stone-100 pt-5 mt-2">
                <div class="flex gap-2">
                  {model.data.modelVariants?.filter(v => v.freeTier).length > 0 ? (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-200">
                      Free Variants Available
                    </span>
                  ) : (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-stone-50 text-stone-500 border border-stone-200">
                      Paid Only
                    </span>
                  )}
                </div>
                
                <a 
                  href={`/${category}/${modelSlug}`} 
                  class="executive-btn text-sm px-5 py-2.5"
                >
                  Read Full Review &rarr;
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</Layout>