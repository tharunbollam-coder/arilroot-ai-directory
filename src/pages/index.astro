---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch all model entries from content layer
const allModels = await getCollection('models');

// Extract unique categories from model entries
const categories = [...new Set(allModels.map(model => model.data.category))];

// Human-friendly mapping for category titles
const categoryDisplayNames: Record<string, string> = {
  'text-models': 'Text Models & Chatbots',
  'image-models': 'Image & Art Generators',
  'audio-models': 'Audio & Speech Synthesizers',
  'video-models': 'Video Generators',
};

// Human-friendly mapping for category descriptions
const categoryDescriptions: Record<string, string> = {
  'text-models': 'Advanced conversational agents, content generation utilities, coding assistants, and deep thinking calculators.',
  'image-models': 'High-fidelity generative AI tools for visual styling, photorealistic artwork, and vector design assets.',
  'audio-models': 'Leading solutions for speech-to-text transcription, AI voiceovers, sound design, and audio composition.',
  'video-models': 'Cutting-edge models transforming prompts and still frames into high-quality cinematic video clips.',
};
---

<Layout title="ArilRoot - Discover the Future of Digital Intelligence">
  <!-- Flat Editorial Hero Section (No Shadows or Borders) -->
  <section class="relative py-20 sm:py-28 md:py-32 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto text-center overflow-hidden">
    <!-- Centered Editorial Headline -->
    <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-stone-900 mb-8 leading-[1.15]">
      Discover the Future of <br />
      <span class="text-stone-900">Digital Intelligence</span>
    </h1>
    
    <!-- Supportive Subtitle -->
    <p class="text-base sm:text-lg md:text-xl text-stone-600 max-w-2xl mx-auto font-normal leading-relaxed mb-12">
      An elegantly curated editorial directory of state-of-the-art AI models. We analyze, detail, and catalog intelligence architectures to simplify integration for modern builders.
    </p>

    <!-- Navigation Prompt/CTA -->
    <div class="flex justify-center gap-4 flex-wrap">
      <a 
        href="#categories" 
        class="executive-btn text-sm px-8 py-4"
      >
        Explore Directories &rarr;
      </a>
    </div>
  </section>

  <!-- Categories Grid Section -->
  <section id="categories" class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto border-t border-stone-200">
    <div class="mb-12 max-w-xl">
      <span class="executive-badge executive-badge-primary mb-3">Curated Architectures</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-stone-900 leading-tight mt-2">
        Browse by Model Domain
      </h2>
      <p class="text-stone-500 mt-3 text-sm font-medium">
        Select a category below to explore individual engine reviews, variants, pricing structure, and best use cases.
      </p>
    </div>

    <!-- Architectural Grid Blocks -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {categories.map((category) => {
        const displayName = categoryDisplayNames[category] || category.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
        const description = categoryDescriptions[category] || `Discover, read review articles, and explore integrations for the latest ${category.replace('-', ' ')} engines.`;
        const count = allModels.filter(m => m.data.category === category).length;

        return (
          <a 
            href={`/${category}`} 
            class="executive-card p-6 sm:p-8 flex flex-col justify-between min-h-[18rem] h-auto group transition-all duration-300"
          >
            <div>
              <!-- Header Meta inside card -->
              <div class="flex items-center justify-between mb-6">
                <span class="executive-badge">
                  {count} {count === 1 ? 'Model' : 'Models'} Available
                </span>
                <span class="text-stone-400 group-hover:text-stone-900 transition-colors">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </span>
              </div>
              
              <!-- Title -->
              <h3 class="font-serif text-2xl font-bold text-stone-900 mb-3 leading-tight">
                {displayName}
              </h3>
              
              <!-- Description -->
              <p class="text-stone-600 text-sm leading-relaxed line-clamp-4 font-normal">
                {description}
              </p>
            </div>
            
            <!-- Footer anchor indicator -->
            <div class="flex items-center justify-between border-t border-stone-100 pt-4 mt-6">
              <span class="font-sans text-[10px] font-bold text-stone-400 uppercase tracking-[0.12em] group-hover:text-stone-900 transition-colors">
                View Collection
              </span>
              <span class="font-sans text-[10px] font-bold text-executive-blue uppercase tracking-[0.12em]">
                Read Reviews &rarr;
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>