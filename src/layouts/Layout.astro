---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "ArilRoot - Premium AI Directory", 
  description = "Discover the future of digital intelligence. A curated catalog of state-of-the-art AI models." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Title and Meta Description for SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Fraunces (serif for headings), Inter (sans-serif for body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col antialiased selection:bg-[#1E3A8A] selection:text-white">
    
    <!-- Premium Executive Top Navigation -->
    <header class="sticky top-0 z-50 bg-[#FAF8F5]/90 backdrop-blur-md border-b border-stone-200 transition-all duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          
          <!-- Elegant Brand Logo -->
          <div class="flex items-center gap-3">
            <a href="https://arilroot.com" class="font-serif text-xl sm:text-2xl font-bold tracking-tight text-stone-900 hover:text-stone-600 transition-colors flex items-center">
              ArilRoot
            </a>
            <span class="text-stone-300 text-lg font-light select-none">|</span>
            <a href="/" class="font-sans text-xs sm:text-sm font-semibold tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">
              AI Directory
            </a>
          </div>
          
          <!-- Desktop Nav Links -->
          <nav class="flex items-center gap-6" aria-label="Main Navigation">
            <a href="/" class="font-sans text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">Home</a>
            <a href="/text-models" class="font-sans text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">Categories</a>
            <a 
              href="https://arilroot.com" 
              class="hidden sm:flex items-center gap-1.5 text-xs font-semibold tracking-wider uppercase text-stone-900 border border-stone-300 rounded-full px-4 py-1.5 hover:bg-stone-100 transition-colors"
            >
              Main Hub
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main Content Slot -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Premium Executive Footer -->
    <footer class="bg-white border-t border-stone-200 py-16 mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
          <div>
            <span class="font-serif text-2xl font-bold text-stone-900 block mb-4">
              ArilRoot AI
            </span>
            <p class="text-stone-500 text-sm leading-relaxed max-w-xs">
              Discover, compare, and learn about the world's most advanced digital models. An executive directory by the ArilRoot Network.
            </p>
          </div>
          <div>
            <h3 class="font-sans text-xs font-bold text-stone-900 uppercase tracking-widest mb-4">Directory</h3>
            <ul class="space-y-3 text-sm text-stone-500">
              <li><a href="/" class="hover:text-stone-900 transition-colors">Directory Home</a></li>
              <li><a href="/text-models" class="hover:text-stone-900 transition-colors">Text Models</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-sans text-xs font-bold text-stone-900 uppercase tracking-widest mb-4">ArilRoot Network</h3>
            <ul class="space-y-3 text-sm text-stone-500">
              <li><a href="https://arilroot.com" class="hover:text-stone-900 transition-colors">Main Hub</a></li>
              <li><a href="https://arilroot.com/about" class="hover:text-stone-900 transition-colors">About Us</a></li>
              <li><a href="https://arilroot.com/contact" class="hover:text-stone-900 transition-colors">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-stone-100 pt-8 flex flex-col sm:flex-row items-center justify-between text-stone-400 text-xs font-medium gap-4">
          <p>&copy; {new Date().getFullYear()} ArilRoot. All rights reserved.</p>
          <div class="flex gap-6">
            <a href="#" class="hover:text-stone-900 transition-colors">Privacy Policy</a>
            <a href="#" class="hover:text-stone-900 transition-colors">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>